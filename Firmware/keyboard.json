{
    "keyboard_name": "nilay/macropad",
    "manufacturer": "nilay",
    "url": "https://github.com/nilay",
    "maintainer": "nilay",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "usb": {
        "vid": "0xFEED",
        "pid": "0x6060",
        "device_version": "1.0.0"
    },
    "features": {
        "bootmagic": true,
        "command": false,
        "console": false,
        "extrakey": true,
        "mousekey": false,
        "nkro": true,
        "encoder": true,
        "oled": true,
        "rgblight": false
    },
    "bootmagic": {
        "matrix": [0, 0]
    },
    "matrix_pins": {
        "rows": ["GP29", "GP0"],
        "cols": ["GP3", "GP4", "GP2", "GP1"]
    },
    "diode_direction": "COL2ROW",
    "encoder": {
        "rotary": [
            {
                "pin_a": "GP26",
                "pin_b": "GP27",
                "resolution": 4
            }
        ]
    },
    "i2c": [
        {
            "name": "I2C0",
            "scl_pin": "GP7",
            "sda_pin": "GP6",
            "clock_speed": 400000
        }
    ],
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [1, 3], "x": 3, "y": 1}
            ]
        }
    }
}
